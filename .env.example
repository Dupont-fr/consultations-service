# Consultation Service - Variables d'environnement
# Copier ce fichier en .env pour le développement

PORT=3003
HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/patients

# JWT (doit être identique pour tous les services)
JWT_SECRET=votre_secret_jwt

# Chiffrement AES-256-GCM (256 bits = 64 caractères hexadécimaux)
# Générer une clé : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS - URL du Gateway en développement
CORS_ORIGIN=http://localhost:3000

# Clé d'authentification inter-services (doit matcher avec user-service)
INTERNAL_API_KEY=medisys-internal-key-2026
